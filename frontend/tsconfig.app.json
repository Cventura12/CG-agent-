{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": false,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true
  },
  "include": [
    "src/vite-env.d.ts",
    "src/main.tsx",
    "src/App.tsx",
    "src/api/client.ts",
    "src/api/voice.ts",
    "src/hooks/useVoiceSessions.ts",
    "src/styles/**/*",
    "src/types/index.ts",
    "src/lib/**/*",
    "src/store/**/*",
    "src/components/shell/**/*",
    "src/components/today/AgentFeedEmpty.tsx",
    "src/components/today/AgentLog.tsx",
    "src/components/today/FeedAside.tsx",
    "src/components/today/StatRow.tsx",
    "src/components/today/TodayView.tsx",
    "src/components/today/TodayViewDemo.tsx",
    "src/components/queue/**/*",
    "src/components/quotes/**/*",
    "src/components/jobs/**/*",
    "src/components/analytics/**/*",
    "src/components/voice/**/*",
    "src/components/ui/**/*"
  ]
}
